# Payload CMS
PAYLOAD_SECRET=your-secret-key-min-32-chars-long-here
DATABASE_URI=file:./data/database.db

# Anthropic (Claude AI — required for chat orchestration)
ANTHROPIC_API_KEY=sk-ant-...

# Cloudflare R2 (S3-compatible storage)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=fullstp-media

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deployment (HestiaCP Server — Phase 1)
DEPLOY_SERVER_IP=167.86.81.161
DEPLOY_SSH_USER=root
DEPLOY_SSH_KEY=/path/to/your/ssh/private/key
# DEPLOY_SSH_PASS=your-ssh-password
